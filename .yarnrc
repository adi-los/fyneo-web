# Yarn v1 project-level configuration
# Applies to ALL `yarn install` calls including platform-generated Dockerfiles.

# 5-minute timeout — handles slow CI/restricted networks
network-timeout 300000

# Skip optional platform binaries (@next/swc-*, lightningcss-win32-*, etc.)
# These are 50MB+ native binaries that time-out or cause extraction errors
# in restricted CI environments. Next.js and Tailwind fall back gracefully.
--install.ignore-optional true

# Allow engine mismatches (camera-controls@3.1.2 requires Node >=22)
--install.ignore-engines true

# Use /app/.yarn-cache (same overlay2 layer as node_modules) not /tmp.
# /tmp is on a separate overlay2 layer that has I/O errors on this CI host.
--cache-folder /app/.yarn-cache
