# Yarn v1 configuration — applies to ALL `yarn install` invocations
# including those in CI/Docker environments.

# Give yarn 5 minutes to download packages (handles slow CI networks)
network-timeout 300000

# Skip optional packages (@next/swc-* native binaries, etc.)
# These are 50MB+ platform-specific binaries that time-out in restricted CI.
# Next.js automatically falls back to Babel when SWC is not present.
--install.ignore-optional true

# Allow engine mismatches (camera-controls@3.1.2 requires Node >=22)
--install.ignore-engines true
